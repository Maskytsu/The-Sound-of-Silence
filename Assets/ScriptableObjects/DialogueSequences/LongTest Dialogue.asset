  m_Script: {fileID: 11500000, guid: 146d4770de626e347adb2af1fed31305, type: 3}
  m_Name: LongTest Dialogue
  m_EditorClassIdentifier: 
  DialogueLines:
  - ColorType: 1
    DisplayTime: 5
    Text: Once when I was little, I had many problems with myself.
  - ColorType: 2
    DisplayTime: 5
    Text: "Then my mother used to tell me that there \nwas some terrifying monster
      out there."
  - ColorType: 3
    DisplayTime: 5
    Text: But it could only harm you if you let it in.
  - ColorType: 4
    DisplayTime: 5
    Text: As a child I didn't really understand this.
  - ColorType: 5
    DisplayTime: 5
    Text: "Let's just say that my mother... \nwasn't a very typical person."
  - ColorType: 6
    DisplayTime: 5
    Text: "But now, as an adult, I\u2019m more afraid \nof that monster more than
      ever."
  - ColorType: 7
    DisplayTime: 5
    Text: So remember to never let it in.
  - ColorType: 8
    DisplayTime: 5
    Text: So remember to never let it in.
