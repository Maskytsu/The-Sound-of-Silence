{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "2f04e22f506b4d01b8c8083fb6359311",
    "m_Title": "",
    "m_Content": "When adding the premulitplied layers together, it can result in non unit vector values for the normal.\nIt is not an issue for the Gbuffer pass because when all layer are added together the final normal value is good.\nIn the Forward pass however, as the blending is done after lighting calculation, it needs a proper normal value, and this is handled by simply reconstructing the Z value..",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": 135.1999969482422,
        "y": -104.0,
        "width": 458.4000244140625,
        "height": 182.39999389648438
    },
    "m_Group": {
        "m_Id": ""
    }
}

