  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "This is the same shader as the WaterStream, but it\u2019s intended to
    be used on a waterfall mesh. It fades out at the start and the end of the mesh
    so that it can be blended in with the stream meshes at the top and bottom of
    the falls, and it adds foam where the falls are vertical.\n\nThe mesh can be
    scaled on the Y axis to match the height between water planes in the stream."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 2f7116f10747a67409388e93052ae222, type: 2}
  m_sharedMaterial: {fileID: -6055507529455485361, guid: 2f7116f10747a67409388e93052ae222,
