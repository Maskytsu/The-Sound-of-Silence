{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "f72c6c7b208e49dea63a0bb81f5fc417",
    "m_Title": "4+ Simple Layer Blend",
    "m_Content": "This shader is designed to support terrains with more than 4 layers in the UniversalRenderPipeline.\n\nThis is done by grouping the layers 4 by 4, premultiplying each layer with its corresponding mask, and adding them together.\n\nThey are then rendered in additives passes, stacking each group of 4 over the previous one.\n\nFor each new pass, the layer indices are shifted back by 4, and the mask index by 1.",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -510.3999938964844,
        "y": -99.19999694824219,
        "width": 263.20001220703127,
        "height": 252.0
    },
    "m_Group": {
        "m_Id": ""
    }
}

